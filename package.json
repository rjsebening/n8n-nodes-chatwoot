{
  "name": "@rjsebening/n8n-nodes-chatwoot",
  "version": "0.0.8",
  "description": "n8n node to connect with ChatWoot",
  "keywords": [
    "n8n-community-node-package",
    "chatwoot"
  ],
  "license": "MIT",
  "homepage": "https://github.com/rjsebening/n8n-nodes-chatwoot#readme",
  "author": {
    "name": "Jörg Sebening",
    "email": "dev@joerg-sebening.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rjsebening/n8n-nodes-chatwoot.git"
  },
  "bugs": {
    "url": "https://github.com/rjsebening/n8n-nodes-chatwoot/issues"
  },
  "main": "index.js",
  "scripts": {
    "build": "npx rimraf dist && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "lint:node": "n8n-node lint",
    "lint:all": "npm run lint && npm run lint:node",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/ChatWootApplicationApi.credentials.js",
      "dist/credentials/ChatWootPlatformApi.credentials.js",
      "dist/credentials/ChatWootClientApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ChatWoot/ChatWootApplication.node.js",
      "dist/nodes/ChatWoot/ChatWootPlatform.node.js",
      "dist/nodes/ChatWoot/ChatWootClient.node.js",
      "dist/nodes/ChatWoot/ChatWootTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.23.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.4",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "gulp-cli": "^3.1.0",
    "package-json-from-dist": "^1.0.1",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}
